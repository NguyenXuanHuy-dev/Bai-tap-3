@{
    ViewData["Title"] = "Cổng Thông Tin Sinh Viên Cao Cấp";
}

<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;1,700&family=Inter:wght@300;400;600&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

<div class="luxury-wrapper py-5">
    <div class="container py-4">
        <div class="row justify-content-center">
            <div class="col-lg-6 col-xl-5">
                <div class="premium-card shadow-2xl">
                    <div class="premium-header text-center mb-5">
                        <div class="logo-emblem mb-4">
                            <i class="bi bi-mortarboard"></i>
                        </div>
                        <h1 class="premium-title mb-1">Cổng Sinh Viên</h1>
                        <div class="premium-subtitle">Đăng Ký Chuyên Ngành Cao Cấp</div>
                        <div class="luxury-line mx-auto mt-4"></div>
                    </div>

                    <form method="post" asp-action="ShowKQ" class="premium-form">
                        <div class="form-group-luxury mb-4">
                            <label class="label-luxury">Mã Số Sinh Viên</label>
                            <div class="input-luxury-wrapper">
                                <input type="text" id="MSSV" name="MSSV" placeholder="Nhập MSSV của bạn" required />
                            </div>
                        </div>

                        <div class="form-group-luxury mb-4">
                            <label class="label-luxury">Họ Và Tên Đầy Đủ</label>
                            <div class="input-luxury-wrapper">
                                <input type="text" id="HoTen" name="HoTen" placeholder="Nhập họ và tên pháp lý" required />
                            </div>
                        </div>

                        <div class="form-group-luxury mb-4">
                            <label class="label-luxury">Năng Lực Học Thuật (GPA)</label>
                            <div class="input-luxury-wrapper">
                                <input type="number" step="0.1" id="DiemTB" name="DiemTB" placeholder="Ví dụ: 4.0" required />
                            </div>
                        </div>

                        <div class="form-group-luxury mb-5">
                            <label class="label-luxury">Chuyên Ngành Học Thuật</label>
                            <div class="input-luxury-wrapper">
                                <select id="ChuyenNganh" name="ChuyenNganh" required>
                                    <option value="" disabled selected>Chọn chuyên ngành của bạn</option>
                                    <option value="CNPM">Công Nghệ Phần Mềm</option>
                                    <option value="HTTT">Hệ Thống Thông Tin</option>
                                    <option value="ANM">An Ninh Mạng</option>
                                    <option value="TTNT">Trí Tuệ Nhân Tạo</option>
                                    <option value="MMT">Mạng Máy Tính</option>
                                </select>
                            </div>
                        </div>

                        <div class="text-center pt-2">
                            <button type="submit" class="btn-luxury-action">
                                <span>Hoàn Tất Đăng Ký</span>
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    :root {
        --luxury-dark: #0a0a0c;
        --luxury-gold: #c5a059;
        --luxury-gold-muted: #8d7340;
        --luxury-text: #e2e2e2;
        --luxury-accent: #1a1a1e;
    }

    body {
        background-color: var(--luxury-dark);
        background-image: radial-gradient(circle at 50% 10%, #1c1c22 0%, var(--luxury-dark) 80%);
        color: var(--luxury-text);
        font-family: 'Inter', sans-serif;
        min-height: 100vh;
    }

    .premium-title {
        font-family: 'Playfair Display', serif;
        font-weight: 700;
        font-size: 2.8rem;
        color: #ffffff;
        letter-spacing: -1px;
    }

    .premium-subtitle {
        font-size: 0.85rem;
        letter-spacing: 5px;
        text-transform: uppercase;
        color: var(--luxury-gold);
        opacity: 0.8;
    }

    .premium-card {
        background: var(--luxury-accent);
        border: 1px solid rgba(197, 160, 89, 0.15);
        border-radius: 40px;
        padding: 60px 45px;
        position: relative;
        box-shadow: 0 40px 100px rgba(0, 0, 0, 0.8);
    }

    .logo-emblem {
        width: 80px;
        height: 80px;
        border: 1px solid var(--luxury-gold);
        border-radius: 50%;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 2.2rem;
        color: var(--luxury-gold);
        background: rgba(197, 160, 89, 0.05);
        box-shadow: 0 0 20px rgba(197, 160, 89, 0.1);
    }

    .luxury-line {
        width: 40px;
        height: 2px;
        background: var(--luxury-gold);
    }

    .label-luxury {
        display: block;
        font-size: 0.65rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 2px;
        color: var(--luxury-gold-muted);
        margin-bottom: 12px;
    }

    .input-luxury-wrapper input, .input-luxury-wrapper select {
        width: 100%;
        background: #121216;
        border: 1px solid #2a2a30;
        border-radius: 12px;
        padding: 16px 20px;
        color: #fff;
        font-size: 0.9rem;
        outline: none;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .input-luxury-wrapper input:focus, .input-luxury-wrapper select:focus {
        border-color: var(--luxury-gold);
        box-shadow: 0 0 0 4px rgba(197, 160, 89, 0.05);
    }

    .btn-luxury-action {
        background: var(--luxury-gold);
        color: #000;
        border: none;
        padding: 20px 50px;
        border-radius: 100px;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 3px;
        font-size: 0.75rem;
        cursor: pointer;
        transition: all 0.4s;
        box-shadow: 0 10px 30px rgba(197, 160, 89, 0.2);
    }

    .btn-luxury-action:hover {
        transform: translateY(-3px);
        background: #d4b470;
        box-shadow: 0 15px 40px rgba(197, 160, 89, 0.4);
    }

    ::placeholder {
        color: #4a4a52;
    }
</style>
